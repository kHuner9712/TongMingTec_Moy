NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=moy_app
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:5176,http://localhost:5177,https://moy.com,https://geo.moy.com,https://api.moy.com,https://app.moy.com

# GEO Leads
GEO_LEAD_NOTIFY_WEBHOOK_TYPE=none
GEO_LEAD_NOTIFY_WEBHOOK_URL=

# API Hub
# ======

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moy_dev

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Provider
API_HUB_PROVIDER_TIMEOUT_MS=60000
