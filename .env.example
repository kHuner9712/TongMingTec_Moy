# ==========================================================
# MOY Repository-Level Environment Template
# ==========================================================
# Usage:
# 1) Backend: copy backend/.env.example -> backend/.env
# 2) Frontend: copy frontend/.env.example -> frontend/.env.development
# 3) This file is a quick reference for collaborators and AI tools.

# ------------------------------
# Backend (NestJS / PostgreSQL)
# ------------------------------
NODE_ENV=development
PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=moy
DB_SYNCHRONIZE=false
DB_LOGGING=true

JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------
# Frontend (Vite)
# ------------------------------
VITE_APP_TITLE=MOY - 墨言
VITE_API_BASE_URL=/api
VITE_CDN_URL=
VITE_ENABLE_SW=false
