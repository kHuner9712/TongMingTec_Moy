# MOY GEO 线索收集后端接口地址
# 留空则使用 localStorage 本地存储（开发调试模式）
# 设置为后端地址则 POST 到真实接口
VITE_GEO_LEAD_ENDPOINT=http://localhost:3001/api/geo/leads

# MOY GEO 内部管理后台 API Base URL
# 用于 /admin/leads 页面调用管理接口
VITE_GEO_ADMIN_API_BASE_URL=http://localhost:3001/api/v1

# production:
# VITE_GEO_LEAD_ENDPOINT=https://api.app.moy.com/api/geo/leads
# VITE_GEO_ADMIN_API_BASE_URL=https://api.app.moy.com/api/v1
